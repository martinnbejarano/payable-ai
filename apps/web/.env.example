# ─── Solana ───────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# ─── Gateway Wallet (backend — receives payments) ─────────────────
# Generate with: solana-keygen new --no-bip39-passphrase
GATEWAY_WALLET_PUBLIC_KEY=
GATEWAY_WALLET_PRIVATE_KEY=

# ─── x402 / Coinbase CDP ──────────────────────────────────────────
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ─── AI Model ─────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── External APIs ────────────────────────────────────────────────
TAVILY_API_KEY=

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
